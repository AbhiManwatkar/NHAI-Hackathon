# =============================================================================
# FaceGuard Offline - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the actual values.
# NEVER commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------
# AWS region for DynamoDB and S3 services
AWS_REGION=ap-south-1

# AWS IAM credentials (use least-privilege IAM role)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# -----------------------------------------------------------------------------
# AWS S3 Configuration
# -----------------------------------------------------------------------------
# S3 bucket for storing facial embeddings and model updates
S3_BUCKET_NAME=nhai-faceguard-data

# -----------------------------------------------------------------------------
# AWS DynamoDB Configuration
# -----------------------------------------------------------------------------
# DynamoDB table for personnel records and authentication logs
DYNAMODB_TABLE_NAME=nhai-faceguard-personnel

# -----------------------------------------------------------------------------
# Sync Configuration
# -----------------------------------------------------------------------------
# Interval (in minutes) between background sync attempts when online
SYNC_INTERVAL_MINUTES=30

# Maximum number of days the app can operate without a successful sync
# After this period, the app will require connectivity to continue
MAX_OFFLINE_DAYS=30

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# AES encryption key size in bits (128, 192, or 256)
ENCRYPTION_KEY_SIZE=256
