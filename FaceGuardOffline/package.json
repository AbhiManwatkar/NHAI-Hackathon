{
  "name": "FaceGuardOffline",
  "version": "1.0.0",
  "private": true,
  "description": "Offline facial recognition and liveness detection system for NHAI field personnel authentication",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "test": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "clean": "cd android && ./gradlew clean && cd .. && rm -rf node_modules/.cache && watchman watch-del-all"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@react-native-community/netinfo": "^11.0.0",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.0.0",
    "@react-navigation/native-stack": "^6.9.26",
    "@react-navigation/stack": "^6.0.0",
    "@tanstack/react-query": "^5.100.14",
    "react": "^18.2.0",
    "react-native": "^0.73.0",
    "react-native-aes-crypto": "^2.1.0",
    "react-native-background-fetch": "^4.2.0",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "^2.0.0",
    "react-native-get-random-values": "^1.11.0",
    "react-native-linear-gradient": "^2.8.0",
    "react-native-reanimated": "^3.0.0",
    "react-native-safe-area-context": "^4.8.0",
    "react-native-screens": "^3.29.0",
    "react-native-sqlite-storage": "^6.0.0",
    "react-native-vector-icons": "^10.0.0",
    "react-native-vision-camera": "^4.0.0",
    "uuid": "^9.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/runtime": "^7.23.0",
    "@react-native/eslint-config": "^0.73.0",
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-native-sqlite-storage": "^6.0.0",
    "@types/uuid": "^9.0.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "prettier": "^2.8.8",
    "react-test-renderer": "^18.2.0",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "moduleNameMapper": {
      "^@modules/(.*)$": "<rootDir>/src/modules/$1",
      "^@screens/(.*)$": "<rootDir>/src/screens/$1",
      "^@components/(.*)$": "<rootDir>/src/components/$1",
      "^@hooks/(.*)$": "<rootDir>/src/hooks/$1",
      "^@theme/(.*)$": "<rootDir>/src/theme/$1",
      "^@utils/(.*)$": "<rootDir>/src/utils/$1",
      "^@navigation/(.*)$": "<rootDir>/src/navigation/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|react-native-vision-camera|react-native-sqlite-storage|@react-native-community|react-native-aes-crypto|react-native-fs|react-native-background-fetch|react-native-reanimated|react-native-gesture-handler|react-native-linear-gradient|react-native-vector-icons|react-native-screens|react-native-safe-area-context|@react-navigation)/)"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/index.ts"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
